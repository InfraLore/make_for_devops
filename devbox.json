{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.12.0/.schema/devbox.schema.json",
  "packages": [
    "texlive.combined.scheme-full@latest",
    "gnumake@latest",
    "pandoc@latest",
    "texlivePackages.xelatex-dev@latest",
    "python310Full@latest",
    "python310Packages.pip@latest",
    "poppler_utils@latest",
    "python@latest",
    "pv@latest"
  ],
  "env": {
    "VENV_DIR": ".venv"
  },
  "shell": {
    "init_hook": [
      "if [ ! -d \"$VENV_DIR\" ]; then",
      "  python -m venv \"$VENV_DIR\";",
      "  . \"$VENV_DIR/bin/activate\";",
      "  pip install --upgrade pip;",
      "  pip install -r requirements.txt || true;",
      "else",
      "  . \"$VENV_DIR/bin/activate\";",
      "  pip install -r requirements.txt || true;",
      "fi"
    ],
    "scripts": {
      "test": ["echo \"Error: no test specified\" && exit 1"],
      "pdf": ["make clean", "make pdf"],
      "final": ["make clean", "make final"],
      "publish": ["make clean", "make publish"]
    }
  }
}
